VITE_SPOTIFY_CLIENT_ID=your_client_id_here
# Optional — defaults to {your-site}/callback when deployed
# VITE_SPOTIFY_REDIRECT_URI=https://your-domain.com/callback

# Required in production for OAuth redirects (set on server, not VITE_)
# PUBLIC_URL=https://your-domain.com

APPLE_TEAM_ID=your_team_id
APPLE_KEY_ID=your_key_id

VITE_YOUTUBE_CLIENT_ID=your-client-id.apps.googleusercontent.com
VITE_YOUTUBE_CLIENT_SECRET=your-client-secret

# Only needed if YouTube shows "Sign in to confirm you're not a bot".
# See TROUBLESHOOTING.md → "YouTube: Sign in to confirm you're not a bot".
#
# Option A — point yt-dlp at a browser you're signed in to YouTube with
# (pick one; close that browser first so its cookie file isn't locked):
#   chrome | firefox | edge | brave | safari | chromium | opera | vivaldi
# YTDLP_COOKIES_FROM_BROWSER=chrome
#
# Option B — use a cookies.txt you exported yourself (full path).
# On Windows use forward slashes, e.g. C:/Users/you/Downloads/cookies.txt
# YTDLP_COOKIES=/absolute/path/to/cookies.txt