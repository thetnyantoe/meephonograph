{
  "name": "cupid-player",
  "version": "0.0.0",
  "private": true,
  "description": "A desktop media player",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/install-yt-dlp.cjs",
    "setup": "node scripts/setup.cjs",
    "dev": "concurrently -k -n vite,electron -c blue,magenta \"vite\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "dev:web": "concurrently -k -n server,vite -c magenta,blue \"node server/index.cjs\" \"vite\"",
    "vite": "vite",
    "build": "vite build",
    "build:electron": "cross-env VITE_BUILD_TARGET=electron vite build",
    "build:web": "vite build",
    "start": "node server/index.cjs",
    "preview": "vite preview",
    "test": "vitest run",
    "electron": "electron .",
    "package": "cross-env VITE_BUILD_TARGET=electron vite build && electron-builder"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "music-metadata": "^11.12.3",
    "music-metadata-browser": "^2.5.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "youtubei.js": "^17.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "nodemon": "^3.1.14",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.codedbycupidity.cupid-player",
    "productName": "Cupid Player",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "audio",
        "to": "audio",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "output": "out"
    },
    "mac": {
      "target": "dir",
      "category": "public.app-category.music",
      "icon": "assets/pink/icon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/pink/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/pink/icon.png"
    }
  }
}
